{
  "name": "ohyo",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev:desktop": "yarn tauri dev",
    "dev:vault": "yarn tauri dev",
    "dev:storybook": "yarn workspace @ohyo/ui storybook",
    "dev:web": "yarn workspace @ohyo/web dev",
    "dev:ui": "yarn workspace @ohyo/ui storybook",
    "dev:internal-tauri": "turbo watch --filter @ohyo/desktop dev",
    "build:ui": "yarn workspace @ohyo/ui build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@tauri-apps/cli": "^2.4.0",
    "@types/node": "^22.13.11",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "homepage": "https://github.com/ohyo-uno/ohyo-app#readme",
  "bugs": {
    "url": "https://github.com/ohyo-uno/ohyo-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ohyo-uno/ohyo-app.git"
  }
}
